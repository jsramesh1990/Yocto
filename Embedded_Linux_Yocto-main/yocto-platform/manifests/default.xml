<?xml version="1.0" encoding="UTF-8"?>
<manifest>
    <!-- Core Yocto Layers -->
    <remote name="yocto" fetch="https://git.yoctoproject.org/git"/>
    <remote name="oe" fetch="https://github.com/openembedded"/>
    <remote name="github" fetch="https://github.com"/>
    
    <!-- Base Layers -->
    <project remote="yocto" name="poky" revision="kirkstone" path="sources/poky"/>
    <project remote="oe" name="meta-openembedded" revision="kirkstone" path="sources/meta-openembedded"/>
    
    <!-- Platform Layer -->
    <project remote="local" name="meta-platform" path="layers/meta-platform"/>
    <project remote="local" name="meta-distro" path="layers/meta-distro"/>
    <project remote="local" name="meta-security" path="layers/meta-security"/>
    <project remote="local" name="meta-ota" path="layers/meta-ota"/>
    <project remote="local" name="meta-apps" path="layers/meta-apps"/>
    
    <!-- BSP Layers (Example set) -->
    <project remote="github" name="agherzan/meta-raspberrypi" revision="kirkstone" path="layers/bsp/meta-raspberrypi"/>
    <project remote="github" name="Freescale/meta-freescale" revision="kirkstone" path="layers/bsp/meta-freescale"/>
    <project remote="github" name="kraj/meta-altera" revision="kirkstone" path="layers/bsp/meta-altera"/>
    
    <!-- Product Layers -->
    <project remote="local" name="meta-camera" path="layers/products/meta-camera"/>
    <project remote="local" name="meta-edgeai" path="layers/products/meta-edgeai"/>
</manifest>
